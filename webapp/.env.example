# Copie para .env.local (dev) e configure as mesmas chaves no painel da Vercel.
# NUNCA commitar valores reais.

# Usuario padrao do login
DASH_USER=admin

# Senha do usuario padrao - OBRIGATORIO definir no deploy
DASH_PASSWORD=

# Segredo usado para assinar o JWT da sessao (front e back usam o mesmo).
# Gere um valor forte, ex.: openssl rand -hex 32
JWT_SECRET=
